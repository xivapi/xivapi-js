{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "declaration": true,
    "preserveConstEnums": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.spec.ts"]
}
